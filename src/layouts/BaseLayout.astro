---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { canonicalUrl, site } from '../lib/site';

const {
	title = site.title,
	description = site.description,
	image = site.defaultOgImage,
	type = 'website',
	publishedAt,
	updatedAt,
	noindex = false,
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonical = canonicalUrl(currentPath);
const imageUrl = image.startsWith('http') ? image : canonicalUrl(image);
---
<!doctype html>
<html lang={site.lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<link rel="canonical" href={canonical} />
		<link rel="icon" href="/favicon.svg" />
		<link rel="alternate" type="application/rss+xml" title="Lenteyyy RSS" href="/rss.xml" />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:locale" content={site.locale} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{publishedAt && <meta property="article:published_time" content={publishedAt} />}
		{updatedAt && <meta property="article:modified_time" content={updatedAt} />}
		<title>{title}</title>
		<script is:inline>
			try {
				const saved = localStorage.getItem('theme');
				if (saved === 'dark' || saved === 'light') document.documentElement.dataset.theme = saved;
			} catch {}
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="shell nav-wrap">
				<a class="brand" href="/">Lenteyyy<span>.</span></a>
				<nav aria-label="主导航">
					<a class={currentPath === '/' ? 'active' : ''} href="/">首页</a>
					<a class={currentPath.startsWith('/posts') || currentPath.startsWith('/tags') ? 'active' : ''} href="/posts">文章</a>
					<a class={currentPath === '/about' ? 'active' : ''} href="/about">关于</a>
					<ThemeToggle />
				</nav>
			</div>
		</header>
		<main><slot /></main>
		<footer class="site-footer">
			<div class="shell footer-inner">
				<span>© {new Date().getFullYear()} Lenteyyy</span>
			</div>
		</footer>
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&display=swap');
	:root {
		color-scheme: light;
		--serif: 'Noto Serif SC', Georgia, serif;
		--mono: 'DM Mono', ui-monospace, monospace;
		--ink: #26231f;
		--muted: #817b71;
		--soft: #aaa196;
		--line: #e4ddd2;
		--paper: #f8f5ef;
		--surface: #efebe2;
		--accent: #9d4a3d;
		--accent-soft: #d8a096;
		--white: #fffdf8;
		--code-bg: #ebe5da;
		--radius: 3px;
		--shadow: 0 18px 45px color-mix(in srgb, var(--ink) 8%, transparent);
		font-family: var(--serif);
	}
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme='light']) {
			color-scheme: dark;
			--ink: #efe9df;
			--muted: #aaa197;
			--soft: #7d756c;
			--line: #383229;
			--paper: #15130f;
			--surface: #211d18;
			--accent: #d69386;
			--accent-soft: #74483e;
			--white: #1b1813;
			--code-bg: #28231d;
			--shadow: 0 18px 45px #00000040;
		}
	}
	:root[data-theme='dark'] {
		color-scheme: dark;
		--ink: #efe9df;
		--muted: #aaa197;
		--soft: #7d756c;
		--line: #383229;
		--paper: #15130f;
		--surface: #211d18;
		--accent: #d69386;
		--accent-soft: #74483e;
		--white: #1b1813;
		--code-bg: #28231d;
		--shadow: 0 18px 45px #00000040;
	}
	* { box-sizing: border-box; }
	body { margin: 0; background: var(--paper); color: var(--ink); text-rendering: optimizeLegibility; }
	a { color: inherit; text-decoration: none; }
	img { max-width: 100%; }
	button, input { font: inherit; }
	:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
	::selection { background: var(--accent-soft); color: var(--ink); }
	.shell { width: min(1180px, calc(100% - 48px)); margin: 0 auto; }
	.site-header { border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, transparent); background: color-mix(in srgb, var(--paper) 91%, transparent); position: sticky; top: 0; z-index: 10; backdrop-filter: blur(16px); }
	.nav-wrap, .footer-inner { min-height: 70px; display: flex; align-items: center; justify-content: space-between; gap: 28px; }
	.brand { font-size: 20px; font-weight: 700; letter-spacing: .01em; transition: color 180ms ease; }
	.brand span { color: var(--accent); }
	.brand:hover { color: var(--accent); }
	nav { display: flex; align-items: center; gap: 26px; color: var(--muted); font-size: 14px; }
	nav a { position: relative; padding: 24px 0 22px; transition: color 180ms ease; }
	nav a::after { content: ''; position: absolute; left: 0; right: 0; bottom: 15px; height: 1px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform 180ms ease; }
	nav a:hover, nav a.active { color: var(--ink); }
	nav a:hover::after, nav a.active::after { transform: scaleX(1); }
	.site-footer { margin-top: 120px; color: var(--muted); font: 11px/1.6 var(--mono); }
	.footer-inner { min-height: 84px; border-top: 1px solid color-mix(in srgb, var(--line) 72%, transparent); }
	@media (max-width: 640px) {
		.shell { width: min(100% - 30px, 1180px); }
		.nav-wrap { min-height: 62px; }
		.brand { font-size: 18px; }
		nav { gap: 14px; font-size: 13px; }
		nav a { padding: 20px 0 17px; }
		.footer-inner { align-items: flex-start; flex-direction: column; justify-content: center; gap: 4px; }
	}
</style>
