---
const { title = 'Lenteyyy', description = 'Lenteyyy 的个人博客' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="shell nav-wrap">
				<a class="brand" href="/">Lenteyyy<span>.</span></a>
				<nav aria-label="主导航">
					<a class:list-active={currentPath === '/'} href="/">首页</a>
					<a class:list-active={currentPath.startsWith('/posts')} href="/posts">文章</a>
					<a href="/about">关于</a>
				</nav>
			</div>
		</header>
		<main><slot /></main>
		<footer class="site-footer">
			<div class="shell footer-inner">
				<span>© {new Date().getFullYear()} Lenteyyy</span>
				<span>写一点，走远一点。</span>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&display=swap');
	:root { color-scheme: light; --ink: #222222; --muted: #77736c; --line: #ddd8cf; --paper: #f7f5f0; --accent: #9b3e2e; --white: #fffdfa; font-family: 'Noto Serif SC', Georgia, serif; }
	* { box-sizing: border-box; }
	body { margin: 0; background: var(--paper); color: var(--ink); }
	a { color: inherit; text-decoration: none; }
	.shell { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }
	.site-header { border-bottom: 1px solid var(--line); background: rgba(247,245,240,.94); position: sticky; top: 0; z-index: 10; backdrop-filter: blur(12px); }
	.nav-wrap, .footer-inner { min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 28px; }
	.brand { font-size: 21px; font-weight: 700; letter-spacing: .02em; }
	.brand span { color: var(--accent); }
	nav { display: flex; gap: 24px; font-size: 14px; color: var(--muted); }
	nav a { padding: 24px 0 20px; border-bottom: 2px solid transparent; }
	nav a:hover, nav a.list-active { color: var(--ink); border-color: var(--accent); }
	.site-footer { margin-top: 100px; border-top: 1px solid var(--line); color: var(--muted); font: 12px/1.6 'DM Mono', monospace; }
	.footer-inner { min-height: 90px; }
	@media (max-width: 640px) { .shell { width: min(100% - 28px, 1120px); } .nav-wrap { min-height: 62px; } nav { gap: 15px; } nav a { padding: 20px 0 17px; } .footer-inner { align-items: flex-start; flex-direction: column; justify-content: center; gap: 4px; } }
</style>
