---
const { title, text, url, locale = 'zh-CN' } = Astro.props as { title: string; text: string; url: string; locale?: 'zh-CN' | 'zh-TW' };
const labels = locale === 'zh-TW' ? { share: '分享文章', opened: '已開啟分享', copied: '連結已複製' } : { share: '分享文章', opened: '已打开分享', copied: '链接已复制' };
---
<div class="share" data-opened-label={labels.opened} data-copied-label={labels.copied}>
	<button type="button" data-share data-title={title} data-text={text} data-url={url}>{labels.share}</button>
	<span role="status" aria-live="polite" data-share-status></span>
</div>

<script>
	const shareLabels = document.querySelector<HTMLElement>('.share');
	const openedLabel = shareLabels?.dataset.openedLabel || '已打开分享';
	const copiedLabel = shareLabels?.dataset.copiedLabel || '链接已复制';
	document.querySelectorAll<HTMLButtonElement>('[data-share]').forEach((button) => {
		button.addEventListener('click', async () => {
			const payload = { title: button.dataset.title || document.title, text: button.dataset.text || '', url: button.dataset.url || location.href };
			const status = button.parentElement?.querySelector('[data-share-status]');
			const canShare = typeof navigator.share === 'function';
			try {
				if (canShare) await navigator.share(payload);
				else await navigator.clipboard.writeText(payload.url);
				if (status) status.textContent = canShare ? openedLabel : copiedLabel;
			} catch {
				if (status) status.textContent = '';
			}
			window.setTimeout(() => { if (status) status.textContent = ''; }, 1800);
		});
	});
</script>

<style>
	.share { display: flex; align-items: center; gap: 12px; }
	button { padding: 0 0 7px; border: 0; border-bottom: 1px solid var(--line); border-radius: 0; background: transparent; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .04em; cursor: pointer; transition: color 180ms ease, border-color 180ms ease; }
	button:hover { color: var(--accent); border-color: var(--accent); }
	span { color: var(--muted); font: 12px var(--mono); }
</style>
