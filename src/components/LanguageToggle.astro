---
---
<div class="language-toggle">
	<button class="language-trigger" type="button" aria-expanded="false" aria-controls="language-menu">语言</button>
	<div class="language-menu" id="language-menu" role="menu" hidden>
		<button type="button" data-language-option="zh-TW" role="menuitem"><span>繁體中文</span></button>
		<button type="button" data-language-option="zh-CN" role="menuitem"><span>简体中文</span></button>
	</div>
</div>

<script>
	import OpenCC from 'opencc-js';

	const root = document.documentElement;
	const trigger = document.querySelector<HTMLButtonElement>('.language-trigger');
	const menu = document.querySelector<HTMLDivElement>('#language-menu');
	const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-language-option]'));
	const converter = OpenCC.Converter({ from: 'cn', to: 'tw' });
	const textNodes: Array<{ node: Text; original: string }> = [];
	const titleOriginal = document.title;
	const metaNodes = Array.from(document.querySelectorAll<HTMLMetaElement>('meta[name="description"], meta[property="og:title"], meta[property="og:description"], meta[name="twitter:title"], meta[name="twitter:description"]')).map((node) => ({ node, original: node.content }));

	const collectTextNodes = () => {
		const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
			acceptNode(node) {
				const parent = node.parentElement;
				if (!parent || /^(SCRIPT|STYLE|CODE|PRE|TEXTAREA|INPUT)$/i.test(parent.tagName)) return NodeFilter.FILTER_REJECT;
				return node.nodeValue?.trim() ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
			},
		});
		let node: Node | null;
		while ((node = walker.nextNode())) textNodes.push({ node: node as Text, original: node.nodeValue || '' });
	};

	const setLanguage = (language: string) => {
		const traditional = language === 'zh-TW';
		root.lang = language;
		textNodes.forEach(({ node, original }) => { node.nodeValue = traditional ? converter(original) : original; });
		document.title = traditional ? converter(titleOriginal) : titleOriginal;
		metaNodes.forEach(({ node, original }) => { node.content = traditional ? converter(original) : original; });
		buttons.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.languageOption === language)));
		try { localStorage.setItem('language', language); } catch {}
	};

	collectTextNodes();
	let saved = 'zh-CN';
	try { saved = localStorage.getItem('language') || saved; } catch {}
	setLanguage(saved === 'zh-TW' ? 'zh-TW' : 'zh-CN');
	buttons.forEach((button) => button.addEventListener('click', () => setLanguage(button.dataset.languageOption || 'zh-CN')));
	const closeMenu = () => { if (!menu || !trigger) return; menu.hidden = true; trigger.setAttribute('aria-expanded', 'false'); };
	trigger?.addEventListener('click', () => { if (!menu) return; menu.hidden = !menu.hidden; trigger.setAttribute('aria-expanded', String(!menu.hidden)); });
	buttons.forEach((button) => button.addEventListener('click', closeMenu));
	document.addEventListener('click', (event) => { if (!event.composedPath().includes(document.querySelector('.language-toggle') as EventTarget)) closeMenu(); });
	document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeMenu(); });
</script>

<style>
	.language-toggle { position: relative; margin-left: 0; }
	.language-trigger { position: relative; padding: 24px 0 22px; border: 0; background: transparent; color: var(--muted); cursor: pointer; font: inherit; transition: color 180ms ease; }
	.language-trigger::after { content: ''; position: absolute; left: 0; right: 0; bottom: 15px; height: 1px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform 180ms ease; }
	.language-trigger:hover, .language-trigger[aria-expanded='true'] { color: var(--ink); }
	.language-trigger:hover::after, .language-trigger[aria-expanded='true']::after { transform: scaleX(1); }
	.language-menu { position: absolute; top: 58px; right: -10px; min-width: 140px; padding: 6px; border: 1px solid var(--line); background: var(--paper); box-shadow: var(--shadow); z-index: 20; }
	.language-menu button { display: flex; width: 100%; align-items: center; padding: 9px 10px; border: 0; background: transparent; color: var(--muted); cursor: pointer; font: 12px/1.4 var(--serif); text-align: left; }
	.language-menu button:hover, .language-menu button[aria-pressed='true'] { background: var(--surface); color: var(--ink); }
	@media (max-width: 640px) { .language-trigger { padding: 20px 0 17px; } .language-menu { top: 52px; right: -8px; } }
</style>
