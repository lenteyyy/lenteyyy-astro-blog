---
import { blockText, blockUrl, escapeAttribute, escapeHtml, type NotionBlock } from '../lib/posts';
const { blocks } = Astro.props as { blocks: NotionBlock[] };

function caption(data: any): string {
	return escapeHtml((data?.caption || []).map((item: any) => item.plain_text || '').join(''));
}

function renderChildren(block: NotionBlock): string {
	return block.children?.map(renderBlock).join('') || '';
}

function renderTable(block: NotionBlock): string {
	const rows = block.children || [];
	return `<div class="table-wrap"><table>${rows.map((row) => {
		const cells = ((row.table_row as any)?.cells || []).map((cell: any[]) => `<td>${cell.map((item) => escapeHtml(item.plain_text || '')).join('')}</td>`).join('');
		return `<tr>${cells}</tr>`;
	}).join('')}</table></div>`;
}

function renderBlock(block: NotionBlock): string {
	const data = block[block.type] as any;
	const text = blockText(block);
	const children = renderChildren(block);
	switch (block.type) {
		case 'paragraph': return text ? `<p>${text}</p>${children}` : children;
		case 'heading_1': return `<h2 id="${escapeAttribute(slug(text))}">${text}</h2>${children}`;
		case 'heading_2': return `<h2 id="${escapeAttribute(slug(text))}">${text}</h2>${children}`;
		case 'heading_3': return `<h3 id="${escapeAttribute(slug(text))}">${text}</h3>${children}`;
		case 'bulleted_list_item': return `<ul><li>${text}${children}</li></ul>`;
		case 'numbered_list_item': return `<ol><li>${text}${children}</li></ol>`;
		case 'to_do': return `<p class="todo"><input type="checkbox" disabled ${data?.checked ? 'checked' : ''} />${text}</p>${children}`;
		case 'toggle': return `<details><summary>${text}</summary>${children}</details>`;
		case 'quote': return `<blockquote>${text}${children}</blockquote>`;
		case 'callout': return `<aside class="callout">${data?.icon?.emoji ? `<span>${escapeHtml(data.icon.emoji)}</span>` : ''}<div>${text}${children}</div></aside>`;
		case 'divider': return '<hr />';
		case 'code': return `<div class="code-wrap"><button type="button" class="copy-code" aria-label="复制代码">复制</button><pre><code>${escapeHtml((data?.rich_text || []).map((item: any) => item.plain_text || '').join(''))}</code></pre></div>`;
		case 'image': {
			const url = blockUrl(block);
			return url ? `<figure><img src="${escapeAttribute(url)}" alt="${caption(data)}" loading="lazy" decoding="async" /><figcaption>${caption(data)}</figcaption></figure>` : '';
		}
		case 'video':
		case 'embed':
		case 'bookmark': {
			const url = blockUrl(block);
			return url ? `<p><a class="embed-link" href="${escapeAttribute(url)}" target="_blank" rel="noreferrer">${escapeHtml(url)} ↗</a></p>` : '';
		}
		case 'table': return renderTable(block);
		case 'child_page': return `<p><strong>${escapeHtml(data?.title || '子页面')}</strong></p>`;
		case 'table_of_contents': return '';
		default: return text ? `<p>${text}</p>${children}` : children;
	}
}

function slug(value: string): string {
	return value.replace(/<[^>]+>/g, '').trim().toLowerCase().replace(/[^\p{Letter}\p{Number}]+/gu, '-').replace(/^-+|-+$/g, '');
}

const html = blocks.map(renderBlock).join('');
---
<div class="notion-content" set:html={html} />

<script>
	document.addEventListener('click', async (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>('.copy-code');
		if (!button) return;
		const code = button.nextElementSibling?.textContent || '';
		await navigator.clipboard?.writeText(code);
		button.textContent = '已复制';
		window.setTimeout(() => { button.textContent = '复制'; }, 1400);
	});
</script>

<style>
	.notion-content { font-size: 17px; line-height: 2.05; }
	.notion-content :global(p) { margin: 0 0 1.25em; }
	.notion-content :global(h2) { margin: 2.2em 0 .65em; font-size: 1.5em; line-height: 1.4; scroll-margin-top: 90px; }
	.notion-content :global(h3) { margin: 1.8em 0 .5em; font-size: 1.18em; line-height: 1.5; scroll-margin-top: 90px; }
	.notion-content :global(a) { color: var(--accent); text-decoration: underline; text-decoration-color: var(--accent-soft); text-underline-offset: 3px; }
	.notion-content :global(code) { padding: 2px 5px; background: var(--code-bg); border-radius: 4px; font: .82em var(--mono); }
	.notion-content :global(blockquote) { margin: 1.8em 0; padding: .1em 1.25em; border-left: 3px solid var(--accent); color: var(--muted); }
	.notion-content :global(ul), .notion-content :global(ol) { padding-left: 1.5em; margin: 0 0 1em; }
	.notion-content :global(li) { padding-left: .35em; }
	.notion-content :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2.8em 0; }
	.notion-content :global(figure) { margin: 2em 0; }
	.notion-content :global(figure img) { display: block; width: 100%; height: auto; max-height: 760px; object-fit: contain; background: var(--surface); }
	.notion-content :global(figcaption) { margin-top: 8px; color: var(--muted); font: 12px/1.6 var(--mono); }
	.notion-content :global(.callout) { display: flex; gap: 12px; padding: 16px 18px; margin: 1.7em 0; background: var(--surface); font-size: .94em; line-height: 1.8; border-radius: var(--radius); }
	.notion-content :global(.callout span) { flex: 0 0 auto; }
	.notion-content :global(.code-wrap) { position: relative; margin: 1.8em 0; }
	.notion-content :global(pre) { overflow-x: auto; padding: 18px; background: #272522; color: #f7f5f0; line-height: 1.7; border-radius: var(--radius); }
	.notion-content :global(pre code) { padding: 0; background: none; color: inherit; }
	.notion-content :global(.copy-code) { position: absolute; right: 8px; top: 8px; padding: 5px 8px; border: 1px solid #ffffff33; border-radius: 4px; background: #00000033; color: #fff; font: 11px var(--mono); cursor: pointer; }
	.notion-content :global(.embed-link) { display: inline-block; padding: 9px 14px; border: 1px solid var(--line); text-decoration: none; font: 12px var(--mono); border-radius: var(--radius); }
	.notion-content :global(details) { margin: 1.2em 0; padding: 12px 14px; background: var(--surface); border-radius: var(--radius); }
	.notion-content :global(summary) { cursor: pointer; }
	.notion-content :global(.todo) { display: flex; gap: 8px; align-items: baseline; }
	.notion-content :global(.table-wrap) { overflow-x: auto; margin: 1.8em 0; }
	.notion-content :global(table) { width: 100%; border-collapse: collapse; min-width: 520px; }
	.notion-content :global(td) { border: 1px solid var(--line); padding: 10px 12px; vertical-align: top; }
	@media (max-width: 640px) { .notion-content { font-size: 16px; line-height: 1.95; } }
</style>
