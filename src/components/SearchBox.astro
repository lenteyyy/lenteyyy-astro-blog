---
type SearchPost = { title: string; slug: string; tags: string[] };
const { posts } = Astro.props as { posts: SearchPost[] };
---
<section class="search-box" aria-label="搜索文章">
	<label>
		<span>SEARCH</span>
		<input type="search" placeholder="标题或标签" data-search-input />
	</label>
	<div class="search-results" data-search-results hidden></div>
</section>

<script is:inline define:vars={{ posts }}>
	const input = document.querySelector('[data-search-input]');
	const results = document.querySelector('[data-search-results]');
	const data = posts;
	input?.addEventListener('input', () => {
		const query = input.value.trim().toLowerCase();
		if (!query) {
			results.hidden = true;
			results.replaceChildren();
			return;
		}
		const matches = data.filter((post) => [post.title, post.tags.join(' ')].join(' ').toLowerCase().includes(query)).slice(0, 8);
		results.hidden = false;
		results.replaceChildren();
		if (!matches.length) {
			const empty = document.createElement('p');
			empty.textContent = '没有找到。';
			results.append(empty);
			return;
		}
		for (const post of matches) {
			const link = document.createElement('a');
			const title = document.createElement('strong');
			const tags = document.createElement('span');
			link.href = `/posts/${encodeURIComponent(post.slug)}`;
			title.textContent = post.title;
			tags.textContent = post.tags.join(' / ');
			link.append(title, tags);
			results.append(link);
		}
	});
</script>

<style>
	.search-box { margin: 0 0 34px; max-width: 760px; }
	label { display: grid; gap: 8px; }
	label span { color: var(--soft); font: 10px/1.5 var(--mono); letter-spacing: .14em; }
	input { width: 100%; padding: 12px 0; border: 0; border-bottom: 1px solid var(--line); border-radius: 0; background: transparent; color: var(--ink); font: 16px var(--serif); }
	input:focus { outline: 0; border-color: var(--accent); }
	.search-results { margin-top: 12px; background: var(--white); box-shadow: var(--shadow); overflow: hidden; }
	.search-results :global(a) { display: grid; gap: 4px; padding: 13px 15px; border-bottom: 1px solid var(--line); }
	.search-results :global(a:last-child) { border-bottom: 0; }
	.search-results :global(a:hover) { color: var(--accent); }
	.search-results :global(span), .search-results :global(p) { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.6; }
</style>
