---
import { formatDisplayDate, type Post } from '../lib/posts';
const { post } = Astro.props as { post: Post };
---
<article class="post-card">
	{post.cover && (
		<a href={`/posts/${post.slug}`} class="cover-link" aria-label={`阅读：${post.title}`}>
			<img src={post.cover} alt={post.title} loading="lazy" decoding="async" />
		</a>
	)}
	<div class="post-card-copy">
		<div class="meta"><span>{post.category}</span><time datetime={post.publishedAt}>{formatDisplayDate(post.publishedAt)}</time></div>
		<h2><a href={`/posts/${post.slug}`}>{post.title}</a></h2>
		<a class="read-more" href={`/posts/${post.slug}`}>阅读全文 <span aria-hidden="true">↗</span></a>
	</div>
</article>

<style>
	.post-card { display: grid; grid-template-columns: minmax(220px, .72fr) minmax(0, 1fr); gap: clamp(22px, 4vw, 48px); padding-top: 30px; border-top: 1px solid color-mix(in srgb, var(--line) 78%, transparent); }
	.post-card:not(:has(.cover-link)) { grid-template-columns: 1fr; }
	.cover-link { display: block; aspect-ratio: 4 / 3; overflow: hidden; background: var(--surface); }
	.cover-link img { width: 100%; height: 100%; object-fit: cover; transition: transform 220ms ease, filter 220ms ease; }
	.cover-link:hover img { transform: scale(1.025); filter: saturate(1.04) contrast(1.02); }
	.post-card-copy { display: flex; flex-direction: column; align-items: flex-start; padding: 2px 0 6px; }
	.meta { display: flex; flex-wrap: wrap; gap: 12px 16px; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .04em; }
	.meta span { color: var(--accent); }
	h2 { max-width: 760px; font-size: clamp(28px, 4vw, 46px); line-height: 1.22; font-weight: 600; margin: 22px 0 12px; letter-spacing: 0; }
	h2 a { transition: color 180ms ease; }
	h2 a:hover { color: var(--accent); }
	.read-more { margin-top: auto; padding-top: 42px; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .04em; transition: color 180ms ease; }
	.read-more:hover { color: var(--accent); }
	.read-more span { font-size: 16px; margin-left: 4px; }
	@media (max-width: 700px) { .post-card { grid-template-columns: 1fr; gap: 18px; padding-top: 24px; } .cover-link { aspect-ratio: 16 / 10; } .post-card-copy { padding-bottom: 4px; } .read-more { margin-top: 18px; padding-top: 0; } h2 { font-size: clamp(25px, 8vw, 34px); } }
</style>
