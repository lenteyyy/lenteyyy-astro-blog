---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import SearchBox from '../../../components/SearchBox.astro';
import { getPosts, type PostCategory } from '../../../lib/posts';
import { localizedPath, translateText } from '../../../lib/locale';

const locale = 'zh-TW' as const;
const posts = await getPosts();
const selectedCategory = Astro.url.searchParams.get('category');
const filteredPosts = selectedCategory ? posts.filter((post) => translateText(post.category, locale) === selectedCategory || post.category === selectedCategory) : posts;
const categories: Array<PostCategory | '全部'> = ['全部', ...new Set<PostCategory>(['酒店測評', ...posts.map((post) => post.category)])];
const path = (value: string) => localizedPath(value, locale);
const categoryHref = (category: string) => path(`/posts/category/${encodeURIComponent(category)}`);
---
<BaseLayout locale={locale} title="文章 · Lenteyyy" description="Lenteyyy 的全部文章。">
	<section class="archive-page shell">
		<div class="page-intro"><p class="eyebrow">THE ARCHIVE</p><h1>文章<span>.</span></h1><p>以下是所有我寫的文章與分類。當然，你亦可使用搜尋功能快速定位你想看的文章。</p></div>
		<SearchBox posts={posts.map(({ title, slug, tags }) => ({ title, slug, tags }))} locale={locale} />
		<nav class="filters" aria-label="文章分類">{categories.map((category) => <a class={(!selectedCategory && category === '全部') || selectedCategory === category || selectedCategory === translateText(category, locale) ? 'selected' : ''} href={category === '全部' ? path('/posts') : categoryHref(category)}>{translateText(category, locale)}</a>)}</nav>
		{filteredPosts.length > 0 ? <div class="post-list">{filteredPosts.map((post) => <PostCard post={post} locale={locale} />)}</div> : <p class="empty">沒有已發布文章。</p>}
	</section>
</BaseLayout>

<style>
	.archive-page { padding-top: 86px; }
	.page-intro { max-width: 760px; padding-bottom: 54px; }
	.eyebrow { margin: 0; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .12em; }
	h1 { margin: 14px 0 18px; font-size: clamp(54px, 9vw, 112px); line-height: .98; font-weight: 600; letter-spacing: -.025em; }
	h1 span { color: var(--accent); }
	.page-intro p:last-child { max-width: 550px; color: var(--muted); font-size: 16px; line-height: 1.9; }
	.filters { display: flex; flex-wrap: wrap; gap: 24px; margin: 0 0 42px; padding-top: 12px; }
	.filters a { color: var(--muted); font: 11px/1.6 var(--mono); letter-spacing: .06em; transition: color 180ms ease; }
	.filters a:hover, .filters a.selected { color: var(--accent); }
	.post-list { display: grid; gap: 42px; }
	.empty { color: var(--muted); font-size: 15px; line-height: 1.9; }
	@media (max-width: 640px) { .archive-page { padding-top: 58px; } .page-intro { padding-bottom: 38px; } }
</style>
