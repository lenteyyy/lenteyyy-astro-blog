---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { getPosts } from '../../../../lib/posts';
import { translateText, type SiteLocale } from '../../../../lib/locale';
const locale: SiteLocale = 'zh-TW';
export async function getStaticPaths() {
	const posts = await getPosts();
	return [...new Set(posts.map((post) => post.category))].map((category) => ({ params: { category }, props: { category } }));
}
const { category } = Astro.props as { category: string };
const posts = (await getPosts()).filter((post) => post.category === category);
const title = translateText(category, locale);
---
<BaseLayout locale={locale} title={`${title} · Lenteyyy`} description={`Lenteyyy 中關於 ${title} 的文章。`}>
	<section class="category-page shell"><p class="eyebrow">CATEGORY</p><h1>{title}<span>.</span></h1><div class="post-list">{posts.map((post) => <PostCard post={post} locale={locale} />)}</div></section>
</BaseLayout>
<style>
	.category-page { padding-top: 86px; } .eyebrow { margin: 0; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .12em; } h1 { margin: 16px 0 54px; font-size: clamp(48px, 8vw, 98px); line-height: 1; font-weight: 600; } h1 span { color: var(--accent); } .post-list { display: grid; gap: 42px; }
</style>
