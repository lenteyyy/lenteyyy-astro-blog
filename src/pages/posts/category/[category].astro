---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPosts } from '../../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPosts();
	const categories = [...new Set(posts.map((post) => post.category))];
	return categories.map((category) => ({ params: { category }, props: { category } }));
}

const { category } = Astro.props as { category: string };
const posts = (await getPosts()).filter((post) => post.category === category);
---
<BaseLayout title={`${category} · Lenteyyy`} description={`Lenteyyy 中关于 ${category} 的文章。`}>
	<section class="category-page shell">
		<p class="eyebrow">CATEGORY</p>
		<h1>{category}<span>.</span></h1>
		<div class="post-list">{posts.map((post) => <PostCard post={post} />)}</div>
	</section>
</BaseLayout>

<style>
	.category-page { padding-top: 86px; }
	.eyebrow { margin: 0; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .12em; }
	h1 { margin: 16px 0 54px; font-size: clamp(48px, 8vw, 98px); line-height: 1; font-weight: 600; letter-spacing: 0; }
	h1 span { color: var(--accent); }
	.post-list { display: grid; gap: 42px; }
</style>
