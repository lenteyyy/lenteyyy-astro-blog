---
import GiscusComments from '../../components/GiscusComments.astro';
import NotionContent from '../../components/NotionContent.astro';
import ShareButton from '../../components/ShareButton.astro';
import ViewCounter from '../../components/ViewCounter.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blockPlainText, formatDisplayDate, getPosts, type NotionBlock } from '../../lib/posts';
import { canonicalUrl, site } from '../../lib/site';

export async function getStaticPaths() {
	const posts = await getPosts();
	return posts.map((post, index) => ({ params: { slug: post.slug }, props: { post, previous: posts[index + 1], next: posts[index - 1] } }));
}

const { post, previous, next } = Astro.props;
const url = canonicalUrl(`/posts/${post.slug}`);
const headings = post.content
	.filter((block: NotionBlock) => ['heading_1', 'heading_2', 'heading_3'].includes(block.type))
	.map((block: NotionBlock) => {
		const text = blockPlainText(block);
		return { text, id: text.trim().toLowerCase().replace(/[^\p{Letter}\p{Number}]+/gu, '-').replace(/^-+|-+$/g, '') };
	})
	.filter((item) => item.text && item.id);
const articleJson = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.title,
	description: post.description,
	image: post.cover ? [post.cover] : [canonicalUrl(site.defaultOgImage)],
	datePublished: post.publishedAt,
	dateModified: post.updatedAt,
	author: { '@type': 'Person', name: site.author },
	mainEntityOfPage: url,
};
---
<BaseLayout title={`${post.title} · Lenteyyy`} description={post.description || site.description} image={post.cover || site.defaultOgImage} type="article" publishedAt={post.publishedAt} updatedAt={post.updatedAt}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(articleJson)} />
	<article class="post-page shell">
		<header class="post-header">
			<a class="back" href="/posts">← 全部文章</a>
			<div class="meta"><span>{post.category}</span><time datetime={post.publishedAt}>{formatDisplayDate(post.publishedAt)}</time><span>{post.readingMinutes} min</span><ViewCounter slug={post.slug} /></div>
			<h1>{post.title}</h1>
			<div class="post-actions"><ShareButton title={post.title} text={post.description} url={url} /></div>
			{post.cover && <img class="hero-image" src={post.cover} alt={post.title} loading="eager" decoding="async" />}
		</header>
		<div class="article-grid">
			<aside class="article-aside">
				{post.tags.length > 0 && <div class="tags">{post.tags.map((tag) => <a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>)}</div>}
				{headings.length > 0 && <nav aria-label="文章目录" class="toc">{headings.map((heading) => <a href={`#${heading.id}`}>{heading.text}</a>)}</nav>}
			</aside>
			<div class="article-body">
				<NotionContent blocks={post.content} />
				<nav class="post-nav" aria-label="上一篇下一篇">
					{previous ? <a href={`/posts/${previous.slug}`}><span>上一篇</span>{previous.title}</a> : <span></span>}
					{next ? <a href={`/posts/${next.slug}`}><span>下一篇</span>{next.title}</a> : <span></span>}
				</nav>
				<GiscusComments />
			</div>
		</div>
	</article>
</BaseLayout>

<style>
	.post-page { padding-top: 62px; }
	.post-header { max-width: 1080px; margin: 0 auto; }
	.back { display: inline-block; margin-bottom: 48px; color: var(--muted); font: 11px/1.6 var(--mono); letter-spacing: .04em; }
	.back:hover { color: var(--accent); }
	.meta { display: flex; flex-wrap: wrap; gap: 12px 16px; color: var(--muted); font: 11px/1.6 var(--mono); letter-spacing: .04em; }
	.meta span:first-child { color: var(--accent); }
	h1 { max-width: 980px; margin: 24px 0 0; font-size: clamp(42px, 7vw, 92px); line-height: 1.12; font-weight: 600; letter-spacing: 0; }
	.post-actions { margin-top: 28px; }
	.hero-image { display: block; width: 100%; aspect-ratio: 16 / 7; height: auto; object-fit: cover; margin-top: 54px; background: var(--surface); }
	.article-grid { display: grid; grid-template-columns: 170px minmax(0, 760px); gap: clamp(38px, 7vw, 86px); justify-content: center; padding-top: 78px; }
	.article-aside { color: var(--muted); font: 11px/1.8 var(--mono); letter-spacing: .02em; }
	.tags { display: flex; flex-wrap: wrap; gap: 7px 11px; margin-bottom: 28px; }
	.tags a:hover, .toc a:hover { color: var(--accent); }
	.toc { position: sticky; top: 100px; display: grid; gap: 9px; }
	.toc a { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
	.post-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 66px; padding-top: 28px; border-top: 1px solid var(--line); }
	.post-nav a { display: grid; gap: 6px; color: var(--ink); }
	.post-nav a:last-child { text-align: right; }
	.post-nav span { color: var(--muted); font: 11px var(--mono); }
	@media (max-width: 760px) {
		.post-page { padding-top: 42px; }
		.back { margin-bottom: 36px; }
		.hero-image { aspect-ratio: 4 / 3; margin-top: 36px; }
		.article-grid { grid-template-columns: 1fr; gap: 30px; padding-top: 52px; }
		.article-aside { order: 2; }
		.article-body { order: 1; }
		.toc { position: static; }
		.post-nav { grid-template-columns: 1fr; }
		.post-nav a:last-child { text-align: left; }
	}
</style>
