---
import NotionContent from '../components/NotionContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNotionPageContent } from '../lib/posts';

const aboutPageId = import.meta.env.NOTION_ABOUT_PAGE_ID || '344e7043-eb63-80b5-b5e0-f416808242fc';
const about = await getNotionPageContent(aboutPageId);
---
<BaseLayout title="关于 · Lenteyyy" description="关于 Lenteyyy。">
	<section class="about shell">
		{about.error ? (
			<p class="about-error">关于页暂时无法读取。</p>
		) : (
			<>
				<h1>{about.title}</h1>
				<div class="about-copy"><NotionContent blocks={about.content} /></div>
			</>
		)}
	</section>
</BaseLayout>

<style>
	.about { padding-top: 110px; min-height: 560px; }
	h1 { margin: 0 0 45px; max-width: 780px; font-size: clamp(36px, 6vw, 72px); line-height: 1.2; font-weight: 600; letter-spacing: 0; }
	.about-copy { max-width: 720px; color: var(--ink); }
	.about-error { color: var(--muted); font-size: 16px; line-height: 1.9; }
	@media (max-width: 640px) { .about { padding-top: 75px; } }
</style>
