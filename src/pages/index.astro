---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPosts } from '../lib/posts';

const posts = await getPosts();
const featured = posts.filter((post) => post.featured).concat(posts).filter((post, index, array) => array.findIndex((item) => item.id === post.id) === index).slice(0, 3);
const categories = [...new Set(posts.map((post) => post.category))];
const categoryHref = (category: string) => `/posts/category/${encodeURIComponent(category)}/`;
---
<BaseLayout title="Lenteyyy · 个人博客" description="酒店、旅行、音乐和一些个人杂谈。">
	<section class="intro shell">
		<div class="intro-copy">
			<p class="eyebrow">HOTEL / TRAVEL / MUSIC</p>
			<h1>欢迎！</h1>
			<p class="lead">你好，我是 Lenteyyy，也可以叫我冷踢踢。这里记录酒店、旅行、音乐和一些还没想明白的事情。</p>
			<div class="intro-links"><a href="/posts">浏览文章 ↗</a><a href="/about">关于我</a></div>
		</div>
		<div class="intro-note">
			<span>Contact</span>
			<a href="mailto:lenteyteytey@gmail.com">lenteyteytey@gmail.com</a>
			<a href="https://www.instagram.com/lenteyyy_/" target="_blank" rel="noreferrer">Instagram: @lenteyyy_</a>
			<div class="social-media">
				<span class="social-title">Social Media</span>
				<a class="social-item" href="https://www.instagram.com/lenteyyy_/" target="_blank" rel="noreferrer"><span class="social-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="4" /><circle cx="12" cy="12" r="3.5" /><circle cx="17.2" cy="6.8" r="1" class="fill" /></svg></span><span>@lenteyyy_</span></a>
				<div class="social-item"><span class="social-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5.2 16.8c-1.2-.9-1.9-2.1-1.9-3.5 0-2.8 3-5.1 6.7-5.1s6.7 2.3 6.7 5.1-3 5.1-6.7 5.1c-.8 0-1.6-.1-2.3-.3l-2.8 1 .7-2.3-.4-.3Z" /><path d="M15.5 8.8c.4-.1.9-.1 1.3-.1 2.2 0 4 1.3 4 3 0 1-.5 1.8-1.3 2.4l.4 1.4-1.7-.6" /></svg></span><span>@冷踢踢</span></div>
				<div class="social-item"><span class="social-icon social-icon-red" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 5.5h8.2c2.1 0 3.8 1.3 3.8 3.1 0 1.1-.7 2.1-1.8 2.6 1.7.4 2.8 1.6 2.8 3.2 0 2.3-2 4.1-4.8 4.1H6V5.5Z" /><path d="M9 8.8h4.8M9 12.3h5.8M9 15.8h3.4" /></svg></span><span>@冷踢踢</span></div>
			</div>
		</div>
	</section>

	<section class="archive shell">
		<div class="section-head"><p class="eyebrow">SELECTED WRITINGS</p><a href="/posts">查看全部 {posts.length} 篇 ↗</a></div>
		{featured.length > 0 ? <div class="post-list">{featured.map((post) => <PostCard post={post} />)}</div> : <p class="empty">Notion 发布数据库目前没有文章。把文章加入数据库并设置 Status 为 Published 后，重新部署即可显示。</p>}
	</section>

	{categories.length > 0 && <section class="categories shell">
		<div class="section-head"><p class="eyebrow">BY CATEGORY</p></div>
		<div class="category-row">{categories.map((category) => <a href={categoryHref(category)}>{category}<span>↗</span></a>)}</div>
	</section>}
</BaseLayout>

<style>
	.intro { min-height: 560px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(180px, 280px); align-items: center; gap: clamp(40px, 8vw, 120px); padding: 58px 0 70px; }
	.eyebrow { margin: 0; color: var(--muted); font: 11px/1.5 var(--mono); letter-spacing: .12em; }
	h1 { margin: 18px 0 30px; font-size: clamp(48px, 8vw, 108px); line-height: .95; letter-spacing: -.03em; font-weight: 600; }
	h1 span { color: var(--accent); }
	.lead { max-width: 480px; margin: 0; color: var(--muted); font-size: 17px; line-height: 1.9; }
	.intro-links { display: flex; gap: 24px; margin-top: 34px; font: 12px var(--mono); letter-spacing: .02em; }
	.intro-links a:first-child { color: var(--accent); }
	.intro-links a:hover { color: var(--accent); }
	.intro-note { align-self: end; width: min(240px, 100%); padding-bottom: 8px; color: var(--muted); }
	.intro-note span { display: block; margin-bottom: 14px; color: var(--soft); font: 10px/1.5 var(--mono); letter-spacing: .14em; text-transform: uppercase; }
	.intro-note a { display: block; color: var(--muted); font-size: 13px; line-height: 1.8; }
	.intro-note a + a { margin-top: 6px; }
	.intro-note a:hover { color: var(--accent); }
	.social-media { margin-top: 34px; }
	.social-title { display: block; margin-bottom: 14px; color: var(--soft); font: 10px/1.5 var(--mono); letter-spacing: .14em; text-transform: uppercase; }
	.social-item { display: flex !important; align-items: center; gap: 8px; color: var(--muted); font-size: 13px; line-height: 1.8; }
	.social-item + .social-item { margin-top: 8px; }
	.social-icon { display: inline-grid; width: 20px; height: 20px; place-items: center; flex: 0 0 20px; border: 1px solid currentColor; color: var(--muted); }
	.social-icon svg { width: 13px; height: 13px; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
	.social-icon svg .fill { fill: currentColor; stroke: none; }
	.social-icon-red { color: #d84a65; }
	.archive { padding-top: 72px; }
	.section-head { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; margin-bottom: 22px; }
	.section-head a { color: var(--muted); font: 11px var(--mono); }
	.section-head a:hover { color: var(--accent); }
	.post-list { display: grid; gap: 42px; }
	.empty { color: var(--muted); font-size: 15px; line-height: 1.9; }
	.categories { padding-top: 96px; }
	.category-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
	.category-row a { display: flex; align-items: center; justify-content: space-between; min-height: 88px; padding: 0 2px; border-top: 1px solid var(--line); color: var(--muted); font-size: 17px; transition: color 180ms ease, border-color 180ms ease; }
	.category-row a:hover { color: var(--accent); }
	.category-row span { font: 16px var(--mono); }
	@media (max-width: 900px) { .intro { grid-template-columns: 1fr; min-height: 0; } .intro-note { align-self: start; } }
	@media (max-width: 700px) { .intro { gap: 34px; padding-top: 52px; padding-bottom: 58px; } .lead { font-size: 16px; } .category-row { grid-template-columns: 1fr; gap: 0; } }
</style>
