---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPosts } from '../lib/posts';

const posts = await getPosts();
const featured = posts.filter((post) => post.featured).concat(posts).filter((post, index, array) => array.findIndex((item) => item.id === post.id) === index).slice(0, 3);
const categories = [...new Set(posts.map((post) => post.category))];
const categoryHref = (category: string) => `/posts/category/${encodeURIComponent(category)}/`;
---
<BaseLayout title="Lenteyyy · 个人博客" description="酒店、旅行、音乐和一些个人杂谈。">
	<section class="intro shell">
		<div class="intro-copy">
			<p class="eyebrow">A PERSONAL ARCHIVE / 2026</p>
			<h1>Lenteyyy<span>.</span></h1>
			<p class="lead">你好，我是 Lenteyyy，也可以叫我冷踢踢。这里记录酒店、旅行、音乐和一些还没想明白的事情。</p>
			<div class="intro-links"><a href="/posts">浏览文章 ↗</a><a href="/about">关于我</a></div>
		</div>
		<div class="intro-note">
			<span>Contact</span>
			<a href="mailto:lenteyteytey@gmail.com">lenteyteytey@gmail.com</a>
			<a href="https://www.instagram.com/lenteyyy_/" target="_blank" rel="noreferrer">Instagram: @lenteyyy_</a>
		</div>
	</section>

	<section class="archive shell">
		<div class="section-head"><p class="eyebrow">SELECTED WRITINGS</p><a href="/posts">查看全部 {posts.length} 篇 ↗</a></div>
		{featured.length > 0 ? <div class="post-list">{featured.map((post) => <PostCard post={post} />)}</div> : <p class="empty">Notion 发布数据库目前没有文章。把文章加入数据库并设置 Status 为 Published 后，重新部署即可显示。</p>}
	</section>

	{categories.length > 0 && <section class="categories shell">
		<div class="section-head"><p class="eyebrow">BY CATEGORY</p></div>
		<div class="category-row">{categories.map((category) => <a href={categoryHref(category)}>{category}<span>↗</span></a>)}</div>
	</section>}
</BaseLayout>

<style>
	.intro { min-height: 510px; display: grid; grid-template-columns: 1.3fr .7fr; align-items: center; gap: 50px; border-bottom: 1px solid var(--line); }
	.eyebrow { margin: 0; color: var(--muted); font: 11px/1.5 'DM Mono', monospace; letter-spacing: .08em; }
	h1 { margin: 18px 0 42px; font-size: clamp(64px, 12vw, 150px); line-height: .9; letter-spacing: -.04em; font-weight: 600; }
	h1 span { color: var(--accent); }
	.lead { max-width: 550px; margin: 0; color: #56514b; font-size: 18px; line-height: 1.85; }
	.intro-links { display: flex; gap: 22px; margin-top: 34px; font: 12px 'DM Mono', monospace; }
	.intro-links a:first-child { color: var(--accent); }
	.intro-note { justify-self: end; width: min(300px, 100%); padding: 22px 0 20px 22px; border-left: 1px solid var(--accent); }
	.intro-note span { display: block; margin-bottom: 18px; color: var(--muted); font: 11px/1.5 'DM Mono', monospace; letter-spacing: .08em; text-transform: uppercase; }
	.intro-note a { display: block; color: var(--ink); font-size: 15px; line-height: 1.85; }
	.intro-note a + a { margin-top: 8px; color: var(--muted); }
	.intro-note a:hover { color: var(--accent); }
	.archive { padding-top: 78px; }
	.section-head { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; margin-bottom: 22px; }
	.section-head a { color: var(--muted); font: 11px 'DM Mono', monospace; }
	.section-head a:hover { color: var(--accent); }
	.post-list { display: grid; gap: 34px; }
	.empty { color: var(--muted); font-size: 15px; line-height: 1.9; }
	.categories { padding-top: 100px; }
	.category-row { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); }
	.category-row a { display: flex; align-items: center; justify-content: space-between; min-height: 90px; padding-right: 18px; border-bottom: 1px solid var(--line); font-size: 18px; }
	.category-row a + a { padding-left: 18px; border-left: 1px solid var(--line); }
	.category-row a:hover { color: var(--accent); }
	.category-row span { font: 16px 'DM Mono', monospace; }
	@media (max-width: 700px) { .intro { min-height: 550px; grid-template-columns: 1fr; gap: 36px; padding-top: 70px; padding-bottom: 60px; } .intro-note { justify-self: start; } .lead { font-size: 16px; } .category-row { grid-template-columns: 1fr; } .category-row a + a { padding-left: 0; border-left: 0; } }
</style>
